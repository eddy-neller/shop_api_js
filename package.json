{
  "name": "en-shop-api-js",
  "version": "0.1.0",
  "private": true,
  "description": "Secondary User API built with NestJS, Prisma, Clean Architecture, DDD and CQRS.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "fixtures:dev": "FIXTURE_GROUP=dev tsx prisma/seed.ts",
    "fixtures:test": "FIXTURE_GROUP=test tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "docker:up": "docker compose up -d --remove-orphans",
    "docker:down": "docker compose down --remove-orphans",
    "docker:build": "docker compose build",
    "docker:build:no-cache": "docker compose build --no-cache",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:shell:db": "docker compose exec database bash"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/cqrs": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.0.0",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "prisma": "^7.8.0",
    "tsx": "^4.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
